  </section>

  <!-- ===== EVOLUTION, NOT REBUILD ===== -->
  <section style="max-width:1180px;margin:0 auto;padding:clamp(56px,8vw,96px) 20px;">
    <div style="display:flex;align-items:center;gap:14px;margin-bottom:34px;">
      <span style="height:3px;flex:1;background:#221913;border-radius:2px;"></span>
      <span style="font-family:'Space Grotesk',monospace;font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:#221913;font-weight:700;white-space:nowrap;">An evolution, not a rebuild</span>
      <span style="height:3px;flex:1;background:#221913;border-radius:2px;"></span>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;">
      <div style="border:2px solid #221913;padding:28px;background:#FFFFFF;">
        <h3 style="font-family:'Anton';font-weight:400;text-transform:uppercase;font-size:28px;margin:0 0 18px;color:#221913;">What we kept</h3>
        <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:12px;">
          <li style="display:flex;gap:10px;font-size:15px;line-height:1.45;"><span style="color:#C8841A;font-weight:700;">&#10003;</span>The Empire Windrush face &mdash; the hull-lettering voice</li>
          <li style="display:flex;gap:10px;font-size:15px;line-height:1.45;"><span style="color:#C8841A;font-weight:700;">&#10003;</span>The warm Pan-African palette</li>
          <li style="display:flex;gap:10px;font-size:15px;line-height:1.45;"><span style="color:#C8841A;font-weight:700;">&#10003;</span>Duotone Black British portraiture, joy-led</li>
          <li style="display:flex;gap:10px;font-size:15px;line-height:1.45;"><span style="color:#C8841A;font-weight:700;">&#10003;</span>23 demands across 3 parts, and the evidence</li>
        </ul>
      </div>
      <div style="border:2px solid #D2331C;padding:28px;background:#221913;color:#F6F2EA;">
        <h3 style="font-family:'Anton';font-weight:400;text-transform:uppercase;font-size:28px;margin:0 0 18px;color:#E3A21E;">What we pushed</h3>
        <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:12px;">
          <li style="display:flex;gap:10px;font-size:15px;line-height:1.45;"><span style="color:#D2331C;font-weight:700;">&rarr;</span>The <strong>manifest</strong> as the spine &mdash; a record we keep for ourselves</li>
          <li style="display:flex;gap:10px;font-size:15px;line-height:1.45;"><span style="color:#D2331C;font-weight:700;">&rarr;</span>Demands as a living record, stamped with how long they've gone unmet</li>
          <li style="display:flex;gap:10px;font-size:15px;line-height:1.45;"><span style="color:#D2331C;font-weight:700;">&rarr;</span>A rolling, date-aware solidarity band &mdash; where intersectionality lives</li>
          <li style="display:flex;gap:10px;font-size:15px;line-height:1.45;"><span style="color:#D2331C;font-weight:700;">&rarr;</span>Vote-up + lived experience, and hull-lettering: cut-in type, riveted seams, a waterline</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section style="background:#D2331C;color:#fff;">
    <div style="max-width:1180px;margin:0 auto;padding:clamp(56px,8vw,96px) 20px;text-align:center;">
      <h2 style="font-family:'Anton';font-weight:400;text-transform:uppercase;line-height:.9;font-size:clamp(40px,8vw,96px);margin:0 0 18px;">Read it. Share it.<br>Act on it.</h2>
      <p style="max-width:50ch;margin:0 auto 30px;font-size:clamp(15px,2vw,19px);line-height:1.6;opacity:.92;">23 demands. Backed by evidence. On the record &mdash; and impossible to erase twice.</p>
      <div style="display:flex;flex-wrap:wrap;gap:14px;justify-content:center;">
        <a href="#manifest" style="background:#221913;color:#F6F2EA;text-decoration:none;font-weight:700;font-size:15px;padding:16px 28px;letter-spacing:.03em;text-transform:uppercase;">Read the manifest</a>
        <a href="#manifest" style="background:#fff;color:#D2331C;text-decoration:none;font-weight:700;font-size:15px;padding:16px 28px;letter-spacing:.03em;text-transform:uppercase;">Add your name</a>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer style="background:#14100B;color:#C8B9A8;">
    <div style="display:flex;align-items:center;gap:10px;max-width:1180px;margin:0 auto;padding:22px 20px 0;">
      <span style="flex:1;height:3px;background:#2B211C;border-radius:2px;"></span>
      <span style="width:9px;height:9px;border-radius:50%;background:#0f0a07;box-shadow:inset 0 1px 1px rgba(227,162,30,.3);"></span>
      <span style="width:9px;height:9px;border-radius:50%;background:#0f0a07;box-shadow:inset 0 1px 1px rgba(227,162,30,.3);"></span>
      <span style="width:9px;height:9px;border-radius:50%;background:#0f0a07;box-shadow:inset 0 1px 1px rgba(227,162,30,.3);"></span>
      <span style="flex:1;height:3px;background:#2B211C;border-radius:2px;"></span>
    </div>
    <div style="max-width:1180px;margin:0 auto;padding:32px 20px 40px;display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:28px;">
      <div>
        <div style="font-family:'Anton';color:#F6F2EA;font-size:20px;text-transform:uppercase;">Black Mental Health Manifest</div>
        <p style="font-size:14px;line-height:1.55;margin:12px 0 0;max-width:36ch;">A Manifesto for Radical Change &mdash; demanding structural change to close the inequity gap for Black people within mental health services in England.</p>
      </div>
      <div>
        <div style="font-family:'Space Grotesk',monospace;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#E3A21E;margin-bottom:12px;">Pages</div>
        <div style="display:flex;flex-direction:column;gap:8px;font-size:14px;">
          <a href="#manifest" style="color:#C8B9A8;text-decoration:none;">The Manifesto</a>
          <a href="#evidence" style="color:#C8B9A8;text-decoration:none;">The Case for Change</a>
          <a href="#manifest" style="color:#C8B9A8;text-decoration:none;">Take Action</a>
          <a href="#manifest" style="color:#C8B9A8;text-decoration:none;">About the Alliance</a>
        </div>
      </div>
      <div>
        <div style="font-family:'Space Grotesk',monospace;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#E3A21E;margin-bottom:12px;">Connect</div>
        <div style="display:flex;flex-direction:column;gap:8px;font-size:14px;">
          <a href="mailto:BlackMHManifesto@gmail.com" style="color:#C8B9A8;text-decoration:none;">Email</a>
        </div>
      </div>
    </div>
    <div style="max-width:1180px;margin:0 auto;padding:0 20px 32px;display:flex;flex-wrap:wrap;gap:10px;justify-content:space-between;font-family:'Space Grotesk',monospace;font-size:12px;color:#6F635A;">
      <span>&copy; 2026 Black Mental Health and Wellbeing Alliance</span>
      <span style="color:#E3A21E;letter-spacing:.12em;">#ProtectBlackMentalHealth</span>
    </div>
  </footer>

</div>

<script is:inline>
(function () {
  var communities = [
    { tag: 'Black & queer', accent: '#E3A21E',
      celebrate: 'Black queer organisers built the ballrooms, the helplines and the chosen families that kept a generation alive.',
      reject: "Reject the misgendering on the ward and the lie that you must choose between your Blackness and your queerness.",
      back: 'Back their joy — care that holds all of who you are, no part left at the door.' },
    { tag: 'Black & disabled', accent: '#D2331C',
      celebrate: 'Black disabled organisers built mutual aid networks that outlasted every funding cycle.',
      reject: 'Reject the assessments that treat survival as a luxury and wards that mistake distress for danger.',
      back: 'Back their joy — access is love, and rest is a right.' },
    { tag: 'Black women', accent: '#E3A21E',
      celebrate: 'Black women hold the clinics, the kitchens and the campaigns — first to be called, last to be cared for.',
      reject: 'Reject being unheard in the consulting room, over-detained on the ward, and told our pain is strength.',
      back: 'Back their joy — softness, safety, and the right to be looked after too.' },
    { tag: 'Black & migrant', accent: '#D2331C',
      celebrate: 'Black migrants rebuilt the NHS they were invited to staff, and the communities that hold it together.',
      reject: "Reject the hostile environment that turns a doctor's room into a border.",
      back: 'Back their joy — sanctuary, dignity, and care without a status check.' },
    { tag: 'Black & of faith', accent: '#E3A21E',
      celebrate: 'Black churches, mosques and temples were the first mental health service many ever trusted.',
      reject: 'Reject services that read faith as a symptom instead of a source of strength.',
      back: 'Back their joy — care that makes room for the spirit, not just the chart.' }
  ];

  var weekIdx = Math.floor(Date.now() / (1000 * 60 * 60 * 24 * 7)) % communities.length;
  var idx = weekIdx;
  var sol = document.getElementById('sol');

  function renderSol() {
    var c = communities[idx];
    sol.style.background = c.accent;
    document.getElementById('sol-tag').textContent = c.tag;
    document.getElementById('sol-celebrate').textContent = c.celebrate;
    document.getElementById('sol-reject').textContent = c.reject;
    document.getElementById('sol-back').textContent = c.back;
    var d = new Date();
    document.getElementById('sol-date').textContent = 'Week of ' + d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
    var dots = communities.map(function (_, i) {
      return '<span style="width:11px;height:11px;border-radius:50%;border:2px solid #1a130d;background:' + (i === idx ? '#1a130d' : 'transparent') + ';"></span>';
    }).join('');
    document.getElementById('sol-dots').innerHTML = dots;
  }
  document.getElementById('sol-next').addEventListener('click', function () {
    idx = (idx + 1) % communities.length; renderSol();
  });
  renderSol();

  // Voting (localStorage)
  var votes = {}, voted = {};
  try { votes = JSON.parse(localStorage.getItem('bmhm_votes') || '{}'); voted = JSON.parse(localStorage.getItem('bmhm_voted') || '{}'); } catch (e) {}
  function fmt(n) { return n >= 1000 ? (n / 1000).toFixed(1).replace('.0', '') + 'k' : String(n); }

  Array.prototype.forEach.call(document.querySelectorAll('[data-vote]'), function (btn) {
    var id = btn.getAttribute('data-vote');
    var seed = parseInt(btn.getAttribute('data-seed'), 10) || 0;
    var wrap = btn.parentNode;
    var countEl = wrap.querySelector('[data-vote-count]');
    var labelEl = btn.querySelector('[data-vote-label]');
    var dark = id === 'd5';
    function paint() {
      var v = (votes[id] || 0) + seed;
      if (countEl) countEl.textContent = fmt(v);
      if (voted[id]) {
        labelEl.textContent = 'Backed';
        btn.style.background = '#E3A21E';
        btn.style.color = '#221913';
      }
    }
    paint();
    btn.addEventListener('click', function () {
      if (voted[id]) return;
      voted[id] = true; votes[id] = (votes[id] || 0) + 1;
      try { localStorage.setItem('bmhm_votes', JSON.stringify(votes)); localStorage.setItem('bmhm_voted', JSON.stringify(voted)); } catch (e) {}
      paint();
    });
  });
})();
</script>
</body>
