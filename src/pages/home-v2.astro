            <p style="margin:0;font-size:14px;line-height:1.55;color:#C8B9A8;">{p.desc}</p>
            <span style="margin-top:auto;font-family:'Space Grotesk',monospace;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:#E3A21E;">{p.count} demands &rarr;</span>
          </a>
        ))}
